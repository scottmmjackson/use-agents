{
  "name": "use-agents",
  "version": "1.0.0",
  "description": "CLI tool for managing context files for agentic coding assistants.",
  "repository": "https://github.com/scottmmjackson/use-agents",
  "main": "dist/index.js",
  "bin": {
    "use-agents": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'README.md' 'AGENTS.md' 'Justfile'",
    "test": "jest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0"
  },
  "private": true
}
